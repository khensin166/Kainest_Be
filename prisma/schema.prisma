generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["kainest"]
}

model Couple {
  id        String   @id @default(uuid())
  user1Id   String
  user2Id   String
  createdAt DateTime @default(now())
  user1     User     @relation("User1Couple", fields: [user1Id], references: [id])
  user2     User     @relation("User2Couple", fields: [user2Id], references: [id])
  notes     Note[]   @relation("CoupleNotes")
  photos    Photo[]
  todos     Todo[]   @relation("CoupleTodos")
  @@schema("kainest")
}

model Photo {
  id         String   @id @default(uuid())
  imageUrl   String
  caption    String?
  coupleId   String?
  uploadedBy String
  createdAt  DateTime @default(now())
  couple     Couple?  @relation(fields: [coupleId], references: [id])
  uploader   User     @relation(fields: [uploadedBy], references: [id])
  
  @@index([coupleId])
  @@schema("kainest")
}

model UserProfile {
  id             String   @id @default(uuid())
  displayName    String?
  avatarUrl      String?
  invitationCode String?  @unique
  createdAt      DateTime @default(now())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  @@schema("kainest")
}

model User {
  id           String            @id @default(uuid())
  email        String            @unique
  password     String?
  name         String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime?         @updatedAt
  phone_number String?           @unique
  whatsappJid  String?           @unique // Untuk menampung @lid atau format JID unik lainnya
  couples1     Couple[]          @relation("User1Couple")
  couples2     Couple[]          @relation("User2Couple")
  notes        Note[]            @relation("UserNotes")
  logs         NotificationLog[]
  notifications AppNotification[]
  feedbacks     UserFeedback[]
  photos       Photo[]
  todos        Todo[]            @relation("UserTodos")
  profile      UserProfile?
  shifts       UserShift[]

  // --- NEW: BUDGETING FIELDS ---
  salary Int @default(0) // Gaji bulanan
  payday Int @default(1) // Tanggal gajian (1-31)

  // Relasi ke fitur Budgeting
  budgetCategories BudgetCategory[] // Kategori custom user
  monthlyHistories MonthlyFinancialHistory[] // Raport keuangan bulanan
  pockets          BudgetPocket[] // Template Kantong User
  transactions     Transaction[] // Catatan pengeluaran
  aiSuggestions    AISuggestion[] // Log saran AI
  emailVerified    Boolean          @default(false)
  image            String?
  sessions         Session[]
  accounts         Account[]
  waBotConfig      WaBotConfig?

  // --- NEW: ROLE & PERMISSIONS (Better Auth Admin Plugin) ---
  role        String?  @default("user")
  banned      Boolean? @default(false)
  banReason   String?
  banExpires  DateTime?
  permissions String[] @default(["budgeting"]) // Array of allowed modules (e.g. ["budgeting", "notes", "todos", "wabot"])

  @@schema("kainest")
}

model UserShift {
  userId     String
  date       DateTime @db.Date
  shift_type String
  createdAt  DateTime @default(now())
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@schema("kainest")
}

model ShiftActivity {
  id            String            @id @default(uuid())
  shift_type    String
  activity_name String
  time_start    String
  reminder_time String
  note          String?
  logs          NotificationLog[]

  @@unique([shift_type, reminder_time])
  @@schema("kainest")
}

model NotificationLog {
  id         String        @id @default(uuid())
  userId     String
  activityId String
  sent_at    DateTime      @default(now())
  activity   ShiftActivity @relation(fields: [activityId], references: [id])
  user       User          @relation(fields: [userId], references: [id])

  @@unique([userId, activityId, sent_at])
  @@schema("kainest")
}

model AppNotification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String   @default("SYSTEM") // 'SYSTEM' | 'ALERT' | 'AI_INSIGHT'
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@schema("kainest")
}

model UserFeedback {
  id        String   @id @default(uuid())
  userId    String
  message   String   @db.Text
  rating    Int?     // 1-5, opsional
  isVisible Boolean  @default(true) // Admin bisa hide
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isVisible])
  @@schema("kainest")
}

model SystemUpdate {
  id          String   @id @default(uuid())
  version     String   @unique // e.g. "v1.3.0"
  title       String
  description String   @db.Text
  date        DateTime // Tanggal rilis dari GitHub
  url         String?  // Link ke GitHub Release
  badge       String?  @default("Baru")
  createdAt   DateTime @default(now())

  @@index([date(sort: Desc)])
  @@schema("kainest")
}

model Todo {
  id           String   @id @default(uuid())
  title        String
  coupleId     String
  createdAt    DateTime @default(now())
  createdById  String
  description  String?
  is_completed Boolean  @default(false)
  updatedAt    DateTime @updatedAt
  couple       Couple   @relation("CoupleTodos", fields: [coupleId], references: [id], onDelete: Cascade)
  createdBy    User     @relation("UserTodos", fields: [createdById], references: [id], onDelete: Cascade)
  
  @@index([coupleId])
  @@index([createdById])
  @@schema("kainest")
}

model Note {
  id                String         @id @default(uuid())
  title             String
  content           Json
  is_public         Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  authorId          String
  coupleId          String?
  partnerPermission NotePermission @default(VIEWER)
  author            User           @relation("UserNotes", fields: [authorId], references: [id], onDelete: Cascade)
  couple            Couple?        @relation("CoupleNotes", fields: [coupleId], references: [id])
  
  @@index([authorId])
  @@index([coupleId])
  @@schema("kainest")
}

enum NotePermission {
  VIEWER
  EDITOR
  @@schema("kainest")
}

// ==========================================
// 💰 FITUR BUDGETING & AI (Kenin System)
// ==========================================

enum TransactionType {
  INCOME
  EXPENSE
  @@schema("kainest")
}

// 1. Kategori (Dinamis: Bisa default sistem, bisa custom user)

model BudgetCategory {
  id        String          @id @default(uuid())
  name      String // Contoh: "Makan", "Transport", "Kost"
  type      TransactionType @default(EXPENSE)
  icon      String? // Emoji atau url icon
  isDefault Boolean         @default(false) // True jika bawaan sistem
  createdAt DateTime        @default(now())

  // TAMBAHAN BARU UNTUK LLM
  keywords  String[]        @default([]) // Contoh: ["makan", "minum", "gofood"]

  userId String? // Nullable. Jika null = Kategori Global (semua user punya)
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]
  pockets      BudgetPocket[] // Relasi ke BudgetPocket

  @@index([userId])
  @@index([isDefault])
  @@schema("kainest")
}

// 2. Raport Keuangan Bulanan (History)
model MonthlyFinancialHistory {
  id              String   @id @default(uuid())
  userId          String
  period          DateTime @db.Date // Tanggal 1 setiap bulan (contoh: 2026-05-01)
  
  // Snapshots (Fotokopi Gaji & Kondisi di bulan tersebut)
  salarySnapshot  Int      // Gaji pada bulan ini
  
  // Agregasi Totals
  totalBudgeted   Int      // Total nilai uang yang dialokasikan ke kantong
  totalSaved      Int      // Total nilai uang yang dialokasikan khusus ke "Tabungan"
  totalSpent      Int      @default(0) // Total pengeluaran bulan ini
  
  // Rincian Kantong (Disimpan sebagai teks JSON)
  pocketsSnapshot Json     
  
  // Ruang untuk AI di masa depan
  aiEvaluation    String?  @db.Text
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, period]) // Hanya boleh 1 raport per user per bulan
  @@schema("kainest")
}

// 2.5 Kantong Budget (Template Limit/Persentase Permanen User)
model BudgetPocket {
  id          String   @id @default(uuid())
  userId      String
  categoryId  String
  
  percentage  Float?   // Persentase alokasi dari total gaji (misal: 15)
  limitAmount Float?   // Atau nominal pasti jika tidak ingin persen (misal: 500000)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    BudgetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 1 user hanya punya 1 pocket per kategori
  @@unique([userId, categoryId]) 
  @@schema("kainest")
}

// 3. Transaksi Harian

model Transaction {
  id     String   @id @default(uuid())
  amount Int
  note   String?
  date   DateTime // Tanggal transaksi terjadi

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId String
  category   BudgetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, date])
  @@index([categoryId])
  @@schema("kainest")
}

// 4. AI Suggestion Logs (Menyimpan saran Groq)

model AISuggestion {
  id              String  @id @default(uuid())
  type            String // 'DAILY_ADVISOR' | 'MONTHLY_EVAL' | 'REBALANCE'
  suggestion_text String  @db.Text
  is_approved     Boolean @default(false) // User setuju dengan saran ini?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@schema("kainest")
}

model WaBotConfig {
  id             String   @id @default(uuid())
  // Field di code: userId, Kolom di DB: user_id
  userId         String   @unique @map("user_id")
  // Field di code: baseUrl, Kolom di DB: base_url
  baseUrl        String   @map("base_url")
  // Field di code: adminSecret, Kolom di DB: admin_secret
  adminSecret    String?  @map("admin_secret")
  // Nomor WA Bot Dinamis
  botPhoneNumber String?  @map("bot_phone_number")
  // Mapping timestamp juga penting
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relasi ke User (Pastikan model User Anda ada di schema ini juga)
  // Jika relasi ini error, Anda bisa menonaktifkannya dulu dengan menghapus baris di bawah ini
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("kainest")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@schema("kainest")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@schema("kainest")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@schema("kainest")
}

// ==========================================
// 🤖 WHATSAPP BOT SYSTEM
// ==========================================

model BotActiveGroup {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  groupId   String   @unique
  createdAt DateTime @default(now())

  @@index([groupId])
  @@schema("kainest")
}

model BackupTargets {
  id         String   @id @default(uuid())
  session_id String
  chat_id    String
  name       String?
  createdAt  DateTime @default(now())

  ChatLogs ChatLogs[]

  @@unique([session_id, chat_id])
  @@index([chat_id])
  @@schema("kainest")
}

model ChatLogs {
  id              String        @id @default(uuid())
  session_id      String
  chat_id         String
  sender          String
  message_content String        @db.Text
  message_type    String        @default("conversation")
  timestamp       DateTime
  raw_data        Json?
  createdAt       DateTime      @default(now())

  BackupTarget BackupTargets @relation(fields: [chat_id, session_id], references: [chat_id, session_id])

  @@index([chat_id, session_id])
  @@index([timestamp(sort: Desc)])
  @@schema("kainest")
}
